        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": "Clicking on any one of the tags will show you in which videos that topic is discussed and how often. You can then click on them to see those annotations!",
          "textSize": "heading-four"
        }
      ]
    },
    {
