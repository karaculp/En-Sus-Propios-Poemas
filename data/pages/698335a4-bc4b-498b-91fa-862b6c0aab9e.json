            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Diana L. Montejano",
                  "textSize": "heading-four"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "(From “Paginas de Mi Vida”)",
                  "textSize": "heading-four"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "There I stood"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "en la calle Guada,"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "selling underground papers"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "por una peseta,"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "shouting words of revolution"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "en las mismas esquinas"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "for aventones to the"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "nearest conexiónes,"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "buscando siempre una solución"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "to la problema"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "of the Tiny Tears doll"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "que dejé in the back seat de"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "tu ‘64 souped-up Falcon."
                }
              ]
            },
