            {
              "type": "paragraph",
              "align": "center",
              "children": [
                {
                  "text": "¿Cuál Hombre O Mujer?",
                  "textSize": "heading-three"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "DIANA L. MONTEJANO",
                  "textSize": "heading-four"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Third Place Spanish",
                  "textSize": "heading-four"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "align": "center",
              "children": [
                {
                  "textSize": "heading-four",
                  "text": ""
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "¿Cuál hombre o mujer puede vivir"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Sin la poesía? ¿Sin la música?"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "¿Sin el arte?"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Qué triste sería este mundo, que pobre,"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Que inutil existencia viajar por las"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Avenidas de la vida pasajera"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Sin ninguna sonrisa o lágrima,"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Sin canción,"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Sin color,"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Sin poesía,"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Reflejando,"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Iluminando,"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Los sentimientos de un hombre"
                }
              ],
              "align": "center"
            },
            {
              "type": "paragraph",
              "align": "center",
              "children": [
                {
                  "text": "O una mujer."
                }
              ]
            }
          ]
        }
